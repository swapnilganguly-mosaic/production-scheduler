# Copy this file to .env for local development (never commit .env to git)
# Set these same variables in your Vercel project → Settings → Environment Variables

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
SPREADSHEET_ID=1_8vj8EFB1xGDpNxn-uUGZNWYG2shDLkWi-Po1s15OTw

# The full JSON content of your Google service account key file (paste as one line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Optional: name of the sheet tab (defaults to "Scheduler Data")
SHEET_NAME=Scheduler Data
